internal class Program
{
    private static void Main(string[] args)
    {
        Console.WriteLine("Lecc16 - Act2 - Inciso1");
        Console.WriteLine("Cuauhtémoc Augusto Barreno Silva/ Clave 5");

        //arreglo - inicializa
        int[] edadPersona = new int[7];
        int cantidadPersonasMayores= 0;

        //solicitar las edadd y almacenar en un arreglo
        for (int i = 0; i < edadPersona.Length; i++)
        {
            Console.Write("Ingrese la edad"+ (i+1) +": ");
            edadPersona[i] =Convert.ToInt32(Console.ReadLine());
            if (edadPersona[i]>=18)
            {
                cantidadPersonasMayores++;
            }
        }

        //Mostrar los datos del arreglo
        Console.Clear();
        Console.Write("Las edades ingreasadas son : ");
        for (int i = 0; i < edadPersona.Length; i++)
        {
            Console.Write(edadPersona[i]+" - ");
        }
        Console.WriteLine("La cantidad de personas Mayores de edad son: "+cantidadPersonasMayores);
    }
}
