Algoritmo Act2_Lecc16_Inc2
Dimensionar numEnt[8]
Definir i,Ma,pMa Como Real
Para i=1 Hasta 8 Hacer
	Escribir "Ingrese el numero ",i, " : "
	Leer numEnt[i]
	si i=1 Entonces
		Ma=numEnt[i]
		pMa=i
	SiNo
		Si numEnt[i]>Ma Entonces
			Ma=numEnt[i]
			pMa=i
		FinSi
	FinSi
Fin Para
Escribir "El numero mayor es: ",Ma
Escribir "Se encuentra en la posicion: ",pMa

	
FinAlgoritmo
